{
  "entities": {
    "vpnUser": {
      "title": "VPN User",
      "description": "A user who can connect to the OpenVPN server",
      "type": "object",
      "properties": {
        "username": { "type": "string", "description": "Unique username for the VPN connection" },
        "password": { "type": "string", "description": "Password or Auth token for the user" },
        "status": { "type": "string", "enum": ["active", "suspended"], "description": "Current status of the user" },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the user was created" },
        "lastConnected": { "type": "string", "format": "date-time", "description": "Last time the user connected" },
        "trafficTotal": { "type": "number", "description": "Total traffic in bytes" }
      },
      "required": ["username", "status", "createdAt"]
    },
    "vpnSession": {
      "title": "VPN Session",
      "description": "An active or past VPN connection session",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "Reference to the vpnUser" },
        "username": { "type": "string" },
        "startTime": { "type": "string", "format": "date-time" },
        "endTime": { "type": "string", "format": "date-time" },
        "remoteIp": { "type": "string" },
        "virtualIp": { "type": "string" },
        "bytesIn": { "type": "number" },
        "bytesOut": { "type": "number" }
      },
      "required": ["userId", "username", "startTime"]
    },
    "serverSettings": {
      "title": "Server Settings",
      "description": "Global settings for the OpenVPN server",
      "type": "object",
      "properties": {
        "publicIp": { "type": "string" },
        "port": { "type": "number" },
        "protocol": { "type": "string", "enum": ["udp", "tcp"] },
        "cipher": { "type": "string" },
        "dnsServer": { "type": "string" }
      }
    },
    "admin": {
      "title": "Admin User",
      "description": "Users who can manage the OpenVPN panel",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["superadmin", "moderator"] }
      }
    }
  },
  "firestore": {
    "/admins/{adminId}": {
      "schema": "admin",
      "description": "List of authorized admins"
    },
    "/vpnUsers/{userId}": {
      "schema": "vpnUser",
      "description": "Collection of VPN users"
    },
    "/sessions/{sessionId}": {
      "schema": "vpnSession",
      "description": "Active and past sessions"
    },
    "/settings/config": {
      "schema": "serverSettings",
      "description": "Global server configuration"
    }
  }
}
